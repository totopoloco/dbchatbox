# Environment Variables Example
# Copy this file to .env and modify as needed

# Spring Boot Configuration
SPRING_PROFILES_ACTIVE=dev

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:h2:mem:testdb
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# JPA Configuration
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true

# Server Configuration
SERVER_PORT=8080

# Chatbox (Spring AI) — Anthropic API key used by the natural-language
# assistant. Create one at https://console.anthropic.com/settings/keys
# and export it before running `./gradlew bootRun`. Leave empty to disable
# the chatbox in environments that shouldn't call external LLMs.
ANTHROPIC_API_KEY=

# Phase 2 — Keycloak M2M client secrets (one per tenant realm, for Variant A API key auth)
# These must match the client secrets configured in each realm's import JSON.
# For production, source from a secrets manager.
KC_M2M_SECRET_WAT_SIMMERING=ChangeMe-WAT-M2M
KC_M2M_SECRET_URW=ChangeMe-URW-M2M
KC_M2M_SECRET_ASV=ChangeMe-ASV-M2M

# Phase 2 — API key HMAC pepper (shared across all tenants)
# REQUIRED: app refuses to start if unset. Generate a strong random value for each environment.
# Example: openssl rand -base64 32
API_KEY_HMAC_SECRET=
