# Environment Variables Example
# Copy this file to .env and modify as needed

# Spring Boot Configuration
SPRING_PROFILES_ACTIVE=dev

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:h2:mem:testdb
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# JPA Configuration
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true

# Server Configuration
SERVER_PORT=8080

# Chatbox (Spring AI) — Anthropic API key used by the natural-language
# assistant. Create one at https://console.anthropic.com/settings/keys
# and export it before running `./gradlew bootRun`. Leave empty to disable
# the chatbox in environments that shouldn't call external LLMs.
ANTHROPIC_API_KEY=

